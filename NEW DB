CREATE PROCEDURE sp_Alta_Empleado
    @Apellido VARCHAR(100),
    @Nombre VARCHAR(100),
    @Cuil VARCHAR(20)
AS
BEGIN
    INSERT INTO Empleado (Apellido, Nombre, Cuil)
    VALUES (@Apellido, @Nombre, @Cuil)
END
GO

CREATE PROCEDURE sp_Registrar_Asistencia
    @Id_Empleado INT,
    @Id_Turno INT,
    @Fecha DATE,
    @HoraEntrada TIME,
    @HoraSalida TIME
AS
BEGIN
    INSERT INTO Asistencia
    VALUES (@Fecha, @HoraEntrada, @HoraSalida, @Id_Empleado, @Id_Turno)
END
GO

CREATE PROCEDURE sp_Registrar_Ingreso
    @Fecha DATE,
    @Id_Origen INT,
    @Id_Empleado INT,
    @Id_TipoFlujo INT
AS
BEGIN
    INSERT INTO Ingreso_Material
    VALUES (@Fecha, @Id_Origen, @Id_Empleado, @Id_TipoFlujo)
END
GO

CREATE PROCEDURE sp_Registrar_Movimiento
    @Fecha DATE,
    @IdTipo INT,
    @IdMaterial INT,
    @Peso DECIMAL(10,2)
AS
BEGIN
    INSERT INTO Movimiento_Material
    (Fecha, Id_Tipo_Movimiento, Id_Material_Clasificado, Peso)
    VALUES (@Fecha, @IdTipo, @IdMaterial, @Peso)
END
