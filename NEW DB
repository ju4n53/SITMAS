CREATE TABLE Marca (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100)
);

CREATE TABLE Modelo (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100),
    Id_Marca INT,
    FOREIGN KEY (Id_Marca) REFERENCES Marca(Id)
);

CREATE TABLE Tipo_Vehiculo (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100)
);

CREATE TABLE Vehiculo (
    Id INT IDENTITY PRIMARY KEY,
    Patente VARCHAR(20),
    Id_Modelo INT,
    Id_Tipo_Vehiculo INT,
