-- ♻️ MATERIALES
--------------------------------------------------

CREATE TABLE Origen (
    Id INT IDENTITY PRIMARY KEY,
    Descripcion VARCHAR(100)
);

CREATE TABLE Tipo_Flujo_Residuo (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100)
);

CREATE TABLE Tipo_Material (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100)
);

CREATE TABLE Sub_Tipo_Material (
    Id INT IDENTITY PRIMARY KEY,
    Id_Tipo_Material INT,
    FOREIGN KEY (Id_Tipo_Material) REFERENCES Tipo_Material(Id)
);

CREATE TABLE Estado_Material (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(50),
    Apto_Produccion BIT
);

CREATE TABLE Ingreso_Material (
    Id INT IDENTITY PRIMARY KEY,
    Fecha DATE,
    Id_Origen INT,
    Id_Empleado INT,
    Id_Tipo_Flujo INT,
    FOREIGN KEY (Id_Origen) REFERENCES Origen(Id),
    FOREIGN KEY (Id_Empleado) REFERENCES Empleado(Id),
    FOREIGN KEY (Id_Tipo_Flujo) REFERENCES Tipo_Flujo_Residuo(Id)
);

CREATE TABLE Detalle_Ingreso (
    Id INT IDENTITY PRIMARY KEY,
    Id_Ingreso INT,
    Id_SubTipoMaterial INT,
    Peso DECIMAL(10,2),
    Observaciones VARCHAR(200),
    FOREIGN KEY (Id_Ingreso) REFERENCES Ingreso_Material(Id),
    FOREIGN KEY (Id_SubTipoMaterial) REFERENCES Sub_Tipo_Material(Id)
);

CREATE TABLE Material_Clasificado (
    Id INT IDENTITY PRIMARY KEY,
    Peso DECIMAL(10,2),
    Id_Empleado INT,
    Id_Detalle_Ingreso INT,
    Id_Estado_Material INT,
    FOREIGN KEY (Id_Empleado) REFERENCES Empleado(Id),
    FOREIGN KEY (Id_Detalle_Ingreso) REFERENCES Detalle_Ingreso(Id),
    FOREIGN KEY (Id_Estado_Material) REFERENCES Estado_Material(Id)
);

CREATE TABLE Tipo_Movimiento (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(50)
);

CREATE TABLE Movimiento_Material (
    Id INT IDENTITY PRIMARY KEY,
    Fecha DATE,
    Peso DECIMAL(10,2),
    Id_Origen INT,
    Id_Empleado INT,
    Id_Material_Clasificado INT,
    Id_Tipo_Movimiento INT,
    FOREIGN KEY (Id_Origen) REFERENCES Origen(Id),
    FOREIGN KEY (Id_Empleado) REFERENCES Empleado(Id),
    FOREIGN KEY (Id_Material_Clasificado) REFERENCES Material_Clasificado(Id),
    FOREIGN KEY (Id_Tipo_Movimiento) REFERENCES Tipo_Movimiento(Id)
);

