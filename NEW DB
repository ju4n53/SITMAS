--------------------------------------------------
-- 📌 TABLAS MAESTRAS
--------------------------------------------------

CREATE TABLE Estado_Empleado (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(50)
);

CREATE TABLE Area (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100)
);

CREATE TABLE Cargo (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100)
);

CREATE TABLE Localidad (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100)
);

CREATE TABLE Barrio (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(100),
    Id_Localidad INT,
    FOREIGN KEY (Id_Localidad) REFERENCES Localidad(Id)
);

--------------------------------------------------
-- 👤 EMPLEADO
--------------------------------------------------

CREATE TABLE Empleado (
    Id INT IDENTITY PRIMARY KEY,
    Apellido VARCHAR(100),
    Nombre VARCHAR(100),
    Cuil VARCHAR(20),
    Fecha_Nacimiento DATE,
    Calle VARCHAR(100),
    Numero INT,
    Telefono VARCHAR(20),
    Email VARCHAR(100),
    Fecha_Ingreso DATE,
    Id_Area INT,
    Id_Cargo INT,
    Id_Barrio INT,
    Id_Estado_Empleado INT,
    FOREIGN KEY (Id_Area) REFERENCES Area(Id),
    FOREIGN KEY (Id_Cargo) REFERENCES Cargo(Id),
    FOREIGN KEY (Id_Barrio) REFERENCES Barrio(Id),
    FOREIGN KEY (Id_Estado_Empleado) REFERENCES Estado_Empleado(Id)
);

--------------------------------------------------
-- 👥 USUARIOS
--------------------------------------------------

CREATE TABLE Estado_Usuario (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(50)
);

CREATE TABLE Usuario (
    Id INT IDENTITY PRIMARY KEY,
    Nombre_Usuario VARCHAR(100),
    Password VARCHAR(100),
    Id_Empleado INT,
    Id_Estado_Usuario INT,
    FOREIGN KEY (Id_Empleado) REFERENCES Empleado(Id),
    FOREIGN KEY (Id_Estado_Usuario) REFERENCES Estado_Usuario(Id)
);

CREATE TABLE Rol (
    Id INT IDENTITY PRIMARY KEY,
    Nombre VARCHAR(50)
);

CREATE TABLE Usuario_Rol (
    Id_Usuario INT,
    Id_Rol INT,
    PRIMARY KEY (Id_Usuario, Id_Rol),
    FOREIGN KEY (Id_Usuario) REFERENCES Usuario(Id),
    FOREIGN KEY (Id_Rol) REFERENCES Rol(Id)
);

--------------------------------------------------
-- 🕒 ASISTENCIA
--------------------------------------------------

CREATE TABLE Turno_Laboral (
    Id INT IDENTITY PRIMARY KEY,
    Fecha DATE,
    Hora_Entrada TIME,
    Hora_Salida TIME
);

CREATE TABLE Asistencia (
    Id INT IDENTITY PRIMARY KEY,
    Fecha DATE,
    Hora_Entrada_Real TIME,
    Hora_Salida_Real TIME,
    Id_Empleado INT,
    Id_Turno INT,
    FOREIGN KEY (Id_Empleado) REFERENCES Empleado(Id),
    FOREIGN KEY (Id_Turno) REFERENCES Turno_Laboral(Id)
);

